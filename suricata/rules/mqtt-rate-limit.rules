# ──────────────────────────────────────────────────────────────────────── 
# mqtt-rate-limit.rules 
# 
# PURPOSE:  Detect MQTT broker flooding / DoS attacks. 
# LOGIC:    Count TCP packets to port 1883 per source IP over a 60-second 
#           sliding window. Alert once the count exceeds 100. 
# TRIGGER:  Any MQTT client sending more than 100 messages per minute. 
# SID:      2000001 
# ──────────────────────────────────────────────────────
alert tcp any any -> any 1883 ( 
msg:"MQTT Excessive Publish Rate — Possible Flood Attack"; 
flow:established,to_server; 
threshold: type threshold, track by_src, count 100, seconds 60; 
classtype:attempted-dos; 
sid:2000001; rev:1; 
) 
