# ──────────────────────────────────────────────────────────────────────── 
# mqtt-malformed-json.rules 
# 
# PURPOSE:  Detect MQTT PUBLISH payloads that are not valid JSON. 
# RULE 2000002: payload contains the string 'undefined' — common bug in 
#               JavaScript IoT clients that serialize unset variables. 
# RULE 2000003: payload starts with a long run of repeated 'A' bytes — 
#               classic buffer-overflow probe or fuzzing pattern. 
# SID range:  2000002–2000003 
# ──────────────────────────────────────────────────────────────────────── 
# mqtt-malformed-json.rules
alert tcp any any -> any 1883 (msg:"MQTT Payload Contains Undefined - Malformed JSON Indicator"; flow:established,to_server; content:"undefined"; classtype:bad-unknown; sid:2000002; rev:1;)

alert tcp any any -> any 1883 (msg:"MQTT Oversized Repeated-Byte Payload - Buffer Overflow Probe"; flow:established,to_server; content:"AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA"; depth:100; classtype:bad-unknown; sid:2000003; rev:1;)
